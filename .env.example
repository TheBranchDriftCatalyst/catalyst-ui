# PaperTradarr API Keys
# Get Polygon.io key (free): https://polygon.io/

# Required - Primary and only quote provider
VITE_POLYGON_API_KEY=your_polygon_key_here

# ────────────────────────────────────────────────────────────────
# LLM Playground demo tab — backend URL defaults.
# All three are optional; the tab's settings row lets you override
# at runtime via localStorage without touching env.

# LiteLLM (chat, embed, compare). Any OpenAI-compatible server.
VITE_LITELLM_URL=http://litellm.talos00
VITE_LITELLM_KEY=

# catalyst-langgraph agent (/agent stream endpoint used by Engine + Chat).
# Tilt injects this in the operator dev stack.
VITE_AGENT_URL=http://localhost:7078
