{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist/lib",
    "skipLibCheck": true,
    "noUnusedLocals": false
  },
  "include": ["lib"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.tsx",
    "**/test/**",
    "**/tests/**",
    "lib/dev/**",
    "lib/effects/Animate/**",
    "lib/effects/MotionFade/**",
    "lib/effects/MotionScale/**",
    "lib/components/ThreeJS/**",
    "lib/components/NavigationHeader/**",
    "lib/cards/CreateAccountCard/**"
  ]
}
